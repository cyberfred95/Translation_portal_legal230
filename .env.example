SECRET_KEY="your-secret-key"
# OPENAI_GPT_API_KEY="your-openai-key"
# SENDGRID_API_KEY="your-sendgrid-key"
GLOSSARY_API_URL="http://your-glossary-api-url:8000/"
GLOSSARY_API_KEY="your-glossary-api-key"
GLOSSARY_SYSTEM="your-glossary-system"

# Cloud Storage API Configuration
CLOUDSTORAGE_API_URL="https://your-cloudstorage-url/"
CLOUDSTORAGE_API_KEY="your-cloudstorage-api-key"

# Active Trail Configuration
ACTIVE_TRAIL_SENDING_PROFILE_ID=your-profile-id
ACTIVE_TRAIL_USER_PROFILE_FROMNAME="Your Name"
ACTIVE_TRAIL_API_KEY="your-activetrail-api-key"

# Stripe Configuration
STRIPE_WEBHOOK_SECRET="your-stripe-webhook-secret"
STRIPE_API_KEY="your-stripe-api-key"

# Statistics Service Configuration
STATS_API_URL="https://your-statistics-url/"
STATS_API_KEY="your-statistics-api-key"

# Emails
SENDER_EMAIL="your-sender-email@domain.com"
QUOTE_CC_EMAIL="your-cc-email@domain.com"
SUPPORT_EMAIL="your-support-email@domain.com"

# Custom MT Console Configuration
CUSTOM_MT_CONSOLE_URL="https://console.custom.mt/"

# LARA Translation API Configuration
LARA_API_URL="http://lara-server:3000"
LARA_ACCESS_KEY_ID="your-lara-access-key-id"
LARA_ACCESS_KEY_SECRET="your-lara-access-key-secret"

# Django Security Configuration
ALLOWED_HOSTS=['api.portail.lexamt.fr', 'api.portail.lexamt.com', 'api.portail.lexamt.tech', '141.253.120.134']

# Django Debug Configuration
DEBUG=True

# PDF Conversion Configuration
# Options: "custommt" (default) or "adobe"
CONVERSION_METHOD="adobe"

# Adobe PDF Services Configuration (required if CONVERSION_METHOD="adobe")
ADOBE_CLIENT_ID="your-adobe-client-id"
ADOBE_CLIENT_SECRET="your-adobe-client-secret"
ADOBE_ORGANIZATION_ID="your-adobe-org-id"
